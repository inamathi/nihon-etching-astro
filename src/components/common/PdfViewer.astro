---
type Props = {
  src: string; // 例: "/pdf/docs_openletter-250525.pdf"
  initialPage?: number;
  initialScale?: number; // 例: 1.2
  minScale?: number;
  maxScale?: number;
  scaleStep?: number; // 例: 0.1
};

const {
  src,
  initialPage = 1,
  initialScale = 1.2,
  minScale = 0.6,
  maxScale = 3.0,
  scaleStep = 0.1,
} = Astro.props;
---

<section class="c-pdf" data-pdf-root data-src={src}>
  <div class="c-pdf__stage">
    <canvas class="c-pdf__canvas" data-canvas></canvas>
  </div>
  <div class="c-pdf__toolbar">
    <div class="c-pdf__pagecontrol">
      <button type="button" class="c-pdf__btn" data-prev>Prev</button>
      <button type="button" class="c-pdf__btn" data-next>Next</button>

      <div class="c-pdf__page">
        <span data-page-now>1</span>/<span data-page-total>1</span>
      </div>

      <label class="c-pdf__jump">
        <span class="c-pdf__label">Go</span>
        <input
          class="c-pdf__input"
          type="number"
          min="1"
          step="1"
          inputmode="numeric"
          data-page-input
        />
        <button type="button" class="c-pdf__btn" data-go>Go</button>
      </label>
    </div>

    <div class="c-pdf__zoom">
      <button type="button" class="c-pdf__btn" data-zoom-out>-</button>
      <button type="button" class="c-pdf__btn" data-zoom-reset>100%</button>
      <button type="button" class="c-pdf__btn" data-zoom-in>+</button>
    </div>

    <a class="c-pdf__btn c-pdf__dl" href="YOUR.pdf" download>
      <svg class="c-pdf__icon" viewBox="0 0 24 24" aria-hidden="true">
        <use
          href="/assets/svg/icon-sprite.svg#icon-download"
          xlink:href="/assets/svg/icon-sprite.svg#icon-download"></use>
      </svg>
    </a>
  </div>
</section>

<script>
  import { mountPdfViewer } from "@/scripts/pdf-viewer";

  (() => {
    const roots = Array.from(document.querySelectorAll("[data-pdf-root]"));

    roots.forEach((root) => {
      if (!(root instanceof HTMLElement)) return;

      mountPdfViewer(root, {
        initialPage: 1,
        initialScale: 1.0,
        minScale: 0.6,
        maxScale: 3.0,
        scaleStep: 0.1,
      });
    });
  })();
</script>
