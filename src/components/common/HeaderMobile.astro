<script>
  (() => {
    const wire = () => {
      const btn = document.querySelector("[data-drawer-btn]");
      const panel = document.querySelector("[data-drawer-panel]");
      const overlay = document.querySelector("[data-drawer-overlay]");

      if (!btn || !panel || !overlay) return;

      // 二重登録防止（Astroのクライアント遷移対策）
      if (btn.hasAttribute("data-drawer-wired")) return;
      btn.setAttribute("data-drawer-wired", "true");

      const open = () => {
        overlay.hidden = false;
        panel.hidden = false;

        // まず閉状態を確実に作ってから次フレームで open
        document.documentElement.classList.remove("is-drawer-open");
        requestAnimationFrame(() => {
          document.documentElement.classList.add("is-drawer-open");
          btn.setAttribute("aria-expanded", "true");
        });
      };

      const close = () => {
        document.documentElement.classList.remove("is-drawer-open");
        btn.setAttribute("aria-expanded", "false");

        // transition があるなら閉じ終わりに合わせて隠す（無ければ即でOK）
        // ここは即 hidden にして問題なければこのままでOK
        overlay.hidden = true;
        panel.hidden = true;
      };

      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        expanded ? close() : open();
      });

      overlay.addEventListener("click", close);

      window.addEventListener(
        "resize",
        () => {
          if (window.matchMedia("(min-width: 1024.01px)").matches) close();
        },
        { passive: true },
      );

      // 初期状態（HTML側で hidden を付け忘れても事故らない）
      close();
    };

    document.addEventListener("DOMContentLoaded", wire);
    document.addEventListener("astro:page-load", wire); // Astro遷移対策
    wire();
  })();
</script>
