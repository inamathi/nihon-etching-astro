---
import { t, toLang, type Lang } from "@/locales/multilingual";

// 親から渡される lang（なければ ja）
const { lang: rawLang = "ja" } = Astro.props as { lang?: string };
const lang: Lang = toLang(rawLang);

// BASE_URL（/ne-staging/ or /）
const baseRoot = import.meta.env.BASE_URL.replace(/\/$/, "");

// 現在のパス（/ne-staging/ja/... など）
const currentPathname = Astro.url.pathname;

// baseRoot を除いた「アプリ内パス」（例: /ja/technology/shibo/）
const appPath = currentPathname.startsWith(baseRoot)
  ? currentPathname.slice(baseRoot.length)
  : currentPathname;

// 言語だけ差し替えた URL を生成
function toLangPath(target: Lang) {
  const replaced = appPath.replace(/^\/(ja|en)(\/|$)/, `/${target}$2`);
  return `${baseRoot}${replaced || `/${target}/`}`;
}

// 言語切替リンク
const hrefJa = toLangPath("ja");
const hrefEn = toLangPath("en");

// 通常リンク用（例：/ne-staging/ja）
const basePath = `${baseRoot}/${lang}`;

// もし「言語を除いたパス」を使う箇所があるなら、これを使う（BASE_URL考慮済み）
const pathNoLang = appPath.replace(/^\/(ja|en)(\/|$)/, "/");
---

<!-- header bar（ここには drawer を入れない） -->
<header class="c-header c-header--mobile" data-site-header>
  <div class="c-header__inner l-container">
    <a class="c-header__logo" href={`${basePath}/`}>Nihon Etching</a>

    <button
      class="c-menuBtn"
      type="button"
      aria-label="Menu"
      aria-expanded="false"
      data-drawer-btn
    >
      <span></span>
    </button>
  </div>
</header>

<!-- overlay（header の外） -->
<div class="c-drawerOverlay" data-drawer-overlay></div>

<div class="c-drawerHint" aria-hidden="true"></div>

<!-- drawer panel（header の外） -->
<aside class="c-drawer" id="drawerPanel" data-drawer-panel>
  <div class="c-drawer__inner l-container">
    <nav class="c-drawer__nav" aria-label="Mobile navigation">
      <a class="c-drawer__link" href={`${basePath}/`}>{t(lang, "nav.top")}</a>

      <div class="c-drawer__group">
        <span class="c-drawer__label">{t(lang, "nav.company")}</span>
        <a
          class="c-drawer__subLink"
          href={`${basePath}/company/overview-access/`}
        >
          {t(lang, "nav.company_overview_access")}
        </a>
        <a class="c-drawer__subLink" href={`${basePath}/company/philosophy/`}>
          {t(lang, "nav.company_philosophy_environment")}
        </a>
        <a class="c-drawer__subLink" href={`${basePath}/company/history/`}>
          {t(lang, "nav.company_history")}
        </a>
      </div>

      <div class="c-drawer__group">
        <span class="c-drawer__label">{t(lang, "nav.technology")}</span>
        <a class="c-drawer__subLink" href={`${basePath}/technology/laser/`}>
          {t(lang, "nav.tech_laser")}
        </a>
        <a class="c-drawer__subLink" href={`${basePath}/technology/shibo/`}>
          {t(lang, "nav.tech_shibo")}
        </a>
        <a class="c-drawer__subLink" href={`${basePath}/technology/peening/`}>
          {t(lang, "nav.tech_peening")}
        </a>
      </div>

      <a class="c-drawer__link" href={`${basePath}/group/`}
        >{t(lang, "nav.group")}</a
      >
      <a class="c-drawer__link" href={`${basePath}/recruit/`}
        >{t(lang, "nav.recruit")}</a
      >
      <a class="c-drawer__link" href={`${basePath}/contact/`}
        >{t(lang, "nav.contact")}</a
      >
      <a class="c-drawer__link" href={`${basePath}/download/`}
        >{t(lang, "nav.download")}</a
      >
    </nav>
    <div class="c-drawer__lang" aria-label="Language">
      <a
        class={`c-drawer__langItem ${lang === "ja" ? "is-current" : ""}`}
        href={hrefJa}
        aria-current={lang === "ja" ? "true" : undefined}>JA</a
      >
      <span class="c-drawer__langSep">|</span>
      <a
        class={`c-drawer__langItem ${lang === "en" ? "is-current" : ""}`}
        href={hrefEn}
        aria-current={lang === "en" ? "true" : undefined}>EN</a
      >
    </div>
  </div>
</aside>
