---
import { t, toLang, type Lang } from "@/locales/multilingual";
import SectionHeading from "../ui/SectionHeading.astro";

const {
  lang: rawLang = "ja",
  images,
  alt = "",
  scale = 2.5,
} = Astro.props as {
  lang?: string;
  images: string[];
  alt?: string;
  scale?: number;
};

const lang: Lang = toLang(rawLang);
const baseRoot = import.meta.env.BASE_URL.replace(/\/$/, "");
const basePath = `${baseRoot}/${lang}`;
---

<section>
  <SectionHeading
    title={t(lang, "zoomViewer.title")}
    subtitle={t(lang, "zoomViewer.subtitle")}
    id="top-about-title"
    as="h2"
    align="center"
    accent="line"
  />
  <div class="zoom-gallery">
    {
      images.map((src, i) => (
        <div class="zoom-viewer" data-zoom-viewer data-scale={scale}>
          <div class="zoom-viewer__frame" data-zoom-frame>
            <img
              class="zoom-viewer__img"
              src={src}
              alt={`${alt} ${i + 1}`}
              draggable="false"
              data-zoom-img
            />
          </div>
          <div class="zoom-viewer__cursor" data-zoom-cursor aria-hidden="true">
            <svg
              class="zoom-viewer__icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <circle cx="11" cy="11" r="7" />
              <line x1="16.5" y1="16.5" x2="22" y2="22" />
              <line
                class="zoom-viewer__icon-h"
                x1="8"
                y1="11"
                x2="14"
                y2="11"
              />
              <line
                class="zoom-viewer__icon-v"
                x1="11"
                y1="8"
                x2="11"
                y2="14"
              />
            </svg>
          </div>
        </div>
      ))
    }
  </div>
  <ul class="fnc-btn-list">
    <li class="list-item">
      <a class="btn" href={`${basePath}${t(lang, "domesticLink.laser.href")}`}>
        {t(lang, "domesticLink.laser.label")}
      </a>
    </li>
  </ul>
</section>

<script>
  document.querySelectorAll("[data-zoom-viewer]").forEach((viewer) => {
    const frame = viewer.querySelector("[data-zoom-frame]");
    const img = viewer.querySelector("[data-zoom-img]");
    const cursor = viewer.querySelector("[data-zoom-cursor]");
    const iconV = viewer.querySelector(".zoom-viewer__icon-v");

    if (!frame || !img || !cursor) return;

    const SCALE = parseFloat(viewer.getAttribute("data-scale") || "2.5");
    let isZoomed = false;
    let mouseX = 0.5;
    let mouseY = 0.5;

    frame.addEventListener("mousemove", (e) => {
      const rect = frame.getBoundingClientRect();
      mouseX = (e.clientX - rect.left) / rect.width;
      mouseY = (e.clientY - rect.top) / rect.height;

      if (isZoomed) applyZoom();

      cursor.style.left = `${e.clientX - rect.left}px`;
      cursor.style.top = `${e.clientY - rect.top}px`;
    });

    frame.addEventListener("mouseenter", () => {
      cursor.style.opacity = "1";
    });

    frame.addEventListener("mouseleave", () => {
      cursor.style.opacity = "0";
    });

    frame.addEventListener("click", (e) => {
      const rect = frame.getBoundingClientRect();
      mouseX = (e.clientX - rect.left) / rect.width;
      mouseY = (e.clientY - rect.top) / rect.height;

      isZoomed = !isZoomed;

      if (isZoomed) {
        applyZoom();
        if (iconV) iconV.style.opacity = "0";
      } else {
        resetZoom();
        if (iconV) iconV.style.opacity = "1";
      }
    });

    function applyZoom() {
      const ox = mouseX * 100;
      const oy = mouseY * 100;
      img.style.transformOrigin = `${ox}% ${oy}%`;
      img.style.transform = `scale(${SCALE})`;
    }

    function resetZoom() {
      img.style.transform = "scale(1)";
      img.style.transformOrigin = "center center";
    }
  });
</script>

<style lang="scss">
  @use "@styles/var" as *;
  @use "@styles/mixin" as *;
  /* ギャラリー：横2枚並び、最大640px */
  .zoom-gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    max-width: calc(640px * 2 + 16px);
    margin: 0 auto;
    padding: 20px;
    background: rgba(0, 0, 0, 0.3);
    margin-bottom: 20px;
  }

  /* SP：縦並び */
  @include bp-down(md) {
    .zoom-gallery {
      grid-template-columns: 1fr;
    }
  }

  /* 各ビューア */
  .zoom-viewer {
    position: relative;
    max-width: 640px;
    width: 100%;
    margin: 0 auto;
  }

  .zoom-viewer__frame {
    position: relative;
    overflow: hidden;
    cursor: none;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #111;
  }

  .zoom-viewer__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform-origin 0s;
    user-select: none;
  }

  /* カスタムカーソル */
  .zoom-viewer__cursor {
    position: absolute;
    top: 0;
    left: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 50%;
    color: #fff;
    pointer-events: none;
    opacity: 0;
    transform: translate(-50%, -50%);
    transition: opacity 0.2s ease;
    z-index: 10;
  }

  .zoom-viewer__icon {
    width: 22px;
    height: 22px;
  }

  .zoom-viewer__icon-v {
    transition: opacity 0.15s ease;
  }

  /* SP：カーソルは非表示（タップ操作のため） */
  @media (max-width: 767px) {
    .zoom-viewer__frame {
      cursor: pointer;
    }
    .zoom-viewer__cursor {
      display: none;
    }
  }
</style>
