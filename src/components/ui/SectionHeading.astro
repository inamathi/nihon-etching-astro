---
type Props = {
  title: string;
  subtitle?: string;
  accent?: "line" | "none";
  align?: "center" | "left";
  as?: "h1" | "h2" | "h3";
  id?: string;
};

const {
  title,
  subtitle,
  accent = "line",
  align = "center",
  as = "h2",
  id,
} = Astro.props as Props;

const Tag = as;
---

<header
  class={`section-heading section-heading--${align}`}
  data-section-heading
>
  <Tag class="section-heading__title" id={id}>
    {title}
  </Tag>

  {subtitle && <p class="section-heading__subtitle">{subtitle}</p>}

  {
    accent === "line" && (
      <span class="section-heading__accent" aria-hidden="true" />
    )
  }
</header>
