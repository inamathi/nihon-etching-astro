---
import { t, toLang, type Lang } from "@/locales/multilingual";

const { lang = "ja" } = Astro.props as { lang?: string };
const safeLang: Lang = toLang(lang);
const basePath = `/${safeLang}`;
---

<header class="c-header c-header--desktop" data-site-header>
  <div class="c-header__inner l-container">
    <a class="c-header__logo" href={`${basePath}/`}>Nihon Etching</a>

    <nav class="c-gnav" aria-label="Global navigation">
      <a class="c-gnav__link" href={`${basePath}/`}>
        {t(safeLang, "nav.top")}
      </a>

      <div class="c-gnav__item has-sub">
        <a class="c-gnav__link" href={`${basePath}/company/overview-access/`}>
          {t(safeLang, "nav.company")}
        </a>
        <div class="c-gnav__sub">
          <a
            class="c-gnav__subLink"
            href={`${basePath}/company/overview-access/`}
          >
            {t(safeLang, "nav.company_overview_access")}
          </a>
          <a class="c-gnav__subLink" href={`${basePath}/company/philosophy/`}>
            {t(safeLang, "nav.company_philosophy_environment")}
          </a>
          <a class="c-gnav__subLink" href={`${basePath}/company/history/`}>
            {t(safeLang, "nav.company_history")}
          </a>
        </div>
      </div>

      <div class="c-gnav__item has-sub">
        <a class="c-gnav__link" href={`${basePath}/technology/`}>
          {t(safeLang, "nav.technology")}
        </a>
        <div class="c-gnav__sub">
          <a class="c-gnav__subLink" href={`${basePath}/technology/5axis/`}>
            {t(safeLang, "nav.tech_5axis")}
          </a>
          <a class="c-gnav__subLink" href={`${basePath}/technology/shibo/`}>
            {t(safeLang, "nav.tech_shibo")}
          </a>
          <a class="c-gnav__subLink" href={`${basePath}/technology/peening/`}>
            {t(safeLang, "nav.tech_peening")}
          </a>
        </div>
      </div>

      <div class="c-gnav__item has-sub">
        <a class="c-gnav__link" href={`${basePath}/group/`}>
          {t(safeLang, "nav.group")}
        </a>
        <div class="c-gnav__sub">
          <a class="c-gnav__subLink" href={`${basePath}/group/ne/`}>
            {t(safeLang, "nav.group_ne")}
          </a>
          <a class="c-gnav__subLink" href={`${basePath}/group/nwn/`}>
            {t(safeLang, "nav.group_nwn")}
          </a>
          <a class="c-gnav__subLink" href={`${basePath}/group/sec/`}>
            {t(safeLang, "nav.group_sec")}
          </a>
        </div>
      </div>

      <a class="c-gnav__link" href={`${basePath}/recruit/`}>
        {t(safeLang, "nav.recruit")}
      </a>
      <a class="c-gnav__link" href={`${basePath}/contact/`}>
        {t(safeLang, "nav.contact")}
      </a>
      <a class="c-gnav__link" href={`${basePath}/download/`}>
        {t(safeLang, "nav.download")}
      </a>
      <!-- 言語切り替えUI -->
      <div class="c-lang" aria-label="Language">
        <a
          class={`c-lang__item ${safeLang === "ja" ? "is-current" : ""}`}
          href={`/ja${Astro.url.pathname.replace(/^\/(ja|en|zh)/, "")}`}
          aria-current={safeLang === "ja" ? "true" : undefined}
        >
          JA
        </a>
        <span class="c-lang__sep">|</span>
        <a
          class={`c-lang__item ${safeLang === "en" ? "is-current" : ""}`}
          href={`/en${Astro.url.pathname.replace(/^\/(ja|en|zh)/, "")}`}
          aria-current={safeLang === "en" ? "true" : undefined}
        >
          EN
        </a>
      </div>
    </nav>
  </div>
</header>

<style lang="scss">
  @use "@styles/var" as *;
  @use "@styles/mixin" as *;
  /* ヘッダーの挙動制御 */
  .c-header,
  .c-header--mobile {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: rgba(0, 0, 0, 0.5);

    /* ここ重要：Heroより前に出す */
    z-index: 3000;

    transform: translateY(0);
    transition: transform 260ms ease;

    /* 背景ぼかし（対応ブラウザ） */
    backdrop-filter: blur(10px) saturate(1.1);
    -webkit-backdrop-filter: blur(10px) saturate(1.1);

    /* フォールバック（未対応環境） */
    background-color: rgba(0, 0, 0, 0.75);

    &.is-hidden {
      transform: translateY(-100%);
    }
  }
  /* 敬遠のユーザーに対しては止める */
  @media (prefers-reduced-motion: reduce) {
    .c-header,
    .c-header--mobile {
      transition: none !important;
    }
  }

  .c-header--desktop {
    .c-header__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 72px;
      gap: 24px;
      padding: 0 $container-padding;
    }

    .c-header__logo {
      color: $color-text;
      font-weight: 700;
      text-decoration: none;
      white-space: nowrap;
    }

    .c-gnav {
      display: flex;
      align-items: center;
      gap: 22px;

      &__link {
        color: $color-text;
        text-decoration: none;
        font-weight: 600;
        white-space: nowrap;
        padding: 12px 0;

        &:hover {
          text-decoration: underline;
        }
      }

      &__item {
        position: relative;
        display: flex;
        align-items: center;

        &.has-sub {
          /* hover が切れないように透明ブリッジを敷く */
          &::before {
            content: "";
            position: absolute;
            left: 0;
            right: 0;
            top: 100%;
            height: 12px; /* 隙間分 */
          }

          .c-gnav__sub {
            display: none;
          }

          &:hover,
          &:focus-within {
            .c-gnav__sub {
              display: block;
            }
          }
        }
      }

      &__sub {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        min-width: 240px;

        background: $color-bg;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 8px;

        /* サブメニューが親の下に重なるように */
        z-index: $z-header;
      }

      &__subLink {
        display: block;
        padding: 10px 10px;
        border-radius: 8px;
        color: $color-text;
        text-decoration: none;
        white-space: nowrap;

        &:hover {
          background: rgba(255, 255, 255, 0.08);
        }
      }
    }
  }
  /* 言語切り替えボタン */
  .c-lang {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: 12px;

    &__item {
      font-weight: 600;
      color: $color-text;
      text-decoration: none;
      opacity: 0.6;

      &.is-current {
        opacity: 1;
        pointer-events: none;
      }

      &:hover {
        opacity: 1;
      }
    }
  }
</style>
