---
import { t, type Lang } from "@/locales/multilingual";
import SectionHeading from "@/components/ui/SectionHeading.astro";

const { lang } = Astro.props as { lang: Lang };
---

<section class="top-about" aria-labelledby="top-about-title">
  <SectionHeading
    title={t(lang, "topAbout.title")}
    subtitle={t(lang, "topAbout.subtitle")}
    id="top-about-title"
    as="h2"
    align="center"
    accent="line"
  />

  <div class="top-about__panel">
    <p class="top-about__tagline">{t(lang, "topAbout.tagline")}</p>
    <div class="top-about__body">
      <p>{t(lang, "topAbout.p1")}</p>
      <p>{t(lang, "topAbout.p2")}</p>
      <p>{t(lang, "topAbout.p3")}</p>
    </div>

    <h3 class="top-about__section">{t(lang, "topAbout.sectionTitle")}</h3>

    <ul class="top-about__cards" aria-label={t(lang, "topAbout.sectionTitle")}>
      <li class="top-about__card">{t(lang, "topAbout.cards.c1")}</li>
      <li class="top-about__card">{t(lang, "topAbout.cards.c2")}</li>
      <li class="top-about__card">{t(lang, "topAbout.cards.c3")}</li>
      <li class="top-about__card">{t(lang, "topAbout.cards.c4")}</li>
      <li class="top-about__card">{t(lang, "topAbout.cards.c5")}</li>
    </ul>
  </div>
</section>

<style lang="scss">
  @use "@styles/var" as *;
  @use "@styles/mixin" as *;

  .top-about {
    padding: 56px 0 72px;
  }

  .top-about__panel {
    width: min(1100px, 100%);
    margin: 0 auto;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 0 $container-padding 30px;
    background: rgba(0, 0, 0, 0.12);
  }

  .top-about__body {
    color: $color-text;
    line-height: 2.05;
    letter-spacing: 0.02em;

    p {
      margin: 0;

      & + p {
        margin-top: 18px;
      }
    }
  }

  .top-about__section {
    margin: 40px 0 20px;
    font-size: clamp(18px, 2.2vw, 22px);
    font-weight: 800;
    letter-spacing: 0.02em;
    color: $color-text;
  }

  .top-about__cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
  }

  .top-about__card {
    padding: 16px 16px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    color: $color-text;
    line-height: 1.8;
    letter-spacing: 0.02em;
  }

  .top-about__tagline {
    margin: 30px 0;
    text-align: center;
    font-weight: 800;
    letter-spacing: 0.22em;
    color: $color-text;
    font-size: clamp(22px, 4vw, 40px);
  }

  @include bp-down(md) {
    .top-about {
      padding: 44px 0 64px;
    }
    .top-about__panel {
      padding: 22px 16px 26px;
    }
    .top-about__body {
      line-height: 2;
    }
    .top-about__tagline {
      letter-spacing: 0.16em;
    }
  }
</style>
