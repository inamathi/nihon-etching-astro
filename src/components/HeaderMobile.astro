---
import { t, toLang, type Lang } from "@/locales/multilingual";

const { lang = "ja" } = Astro.props as { lang?: string };
const safeLang: Lang = toLang(lang);
const basePath = `/${safeLang}`;
const pathNoLang = Astro.url.pathname.replace(/^\/(ja|en|zh)/, "");
---

<!-- header bar（ここには drawer を入れない） -->
<header class="c-header c-header--mobile" data-site-header>
  <div class="c-header__inner l-container">
    <a class="c-header__logo" href={`${basePath}/`}>Nihon Etching</a>

    <button
      class="c-menuBtn"
      type="button"
      aria-label="Menu"
      aria-expanded="false"
      data-drawer-btn
    >
      <span></span>
    </button>
  </div>
</header>

<!-- overlay（header の外） -->
<div class="c-drawerOverlay" data-drawer-overlay></div>

<div class="c-drawerHint" aria-hidden="true"></div>

<!-- drawer panel（header の外） -->
<aside class="c-drawer" id="drawerPanel" data-drawer-panel>
  <div class="c-drawer__inner l-container">
    <nav class="c-drawer__nav" aria-label="Mobile navigation">
      <a class="c-drawer__link" href={`${basePath}/`}
        >{t(safeLang, "nav.top")}</a
      >

      <div class="c-drawer__group">
        <span class="c-drawer__label">{t(safeLang, "nav.company")}</span>
        <a
          class="c-drawer__subLink"
          href={`${basePath}/company/overview-access/`}
        >
          {t(safeLang, "nav.company_overview_access")}
        </a>
        <a class="c-drawer__subLink" href={`${basePath}/company/philosophy/`}>
          {t(safeLang, "nav.company_philosophy_environment")}
        </a>
        <a class="c-drawer__subLink" href={`${basePath}/company/history/`}>
          {t(safeLang, "nav.company_history")}
        </a>
      </div>

      <div class="c-drawer__group">
        <span class="c-drawer__label">{t(safeLang, "nav.technology")}</span>
        <a class="c-drawer__subLink" href={`${basePath}/technology/5axis/`}>
          {t(safeLang, "nav.tech_5axis")}
        </a>
        <a class="c-drawer__subLink" href={`${basePath}/technology/shibo/`}>
          {t(safeLang, "nav.tech_shibo")}
        </a>
        <a class="c-drawer__subLink" href={`${basePath}/technology/peening/`}>
          {t(safeLang, "nav.tech_peening")}
        </a>
      </div>

      <a class="c-drawer__link" href={`${basePath}/group/`}
        >{t(safeLang, "nav.group")}</a
      >
      <a class="c-drawer__link" href={`${basePath}/recruit/`}
        >{t(safeLang, "nav.recruit")}</a
      >
      <a class="c-drawer__link" href={`${basePath}/contact/`}
        >{t(safeLang, "nav.contact")}</a
      >
      <a class="c-drawer__link" href={`${basePath}/download/`}
        >{t(safeLang, "nav.download")}</a
      >
    </nav>
    <div class="c-drawer__lang" aria-label="Language">
      <a
        class={`c-drawer__langItem ${safeLang === "ja" ? "is-current" : ""}`}
        href={`/ja${pathNoLang}`}
        aria-current={safeLang === "ja" ? "true" : undefined}>JA</a
      >
      <span class="c-drawer__langSep">|</span>
      <a
        class={`c-drawer__langItem ${safeLang === "en" ? "is-current" : ""}`}
        href={`/en${pathNoLang}`}
        aria-current={safeLang === "en" ? "true" : undefined}>EN</a
      >
    </div>
  </div>
</aside>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.querySelector<HTMLButtonElement>("[data-drawer-btn]");
    const overlay = document.querySelector<HTMLElement>(
      "[data-drawer-overlay]"
    );

    if (!btn || !overlay) return;

    const open = () => {
      document.documentElement.classList.remove("is-drawer-open");
      requestAnimationFrame(() => {
        document.documentElement.classList.add("is-drawer-open");
        btn.setAttribute("aria-expanded", "true");
      });
    };

    const close = () => {
      document.documentElement.classList.remove("is-drawer-open");
      btn.setAttribute("aria-expanded", "false");
    };

    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      expanded ? close() : open();
    });

    overlay.addEventListener("click", close);

    window.addEventListener("resize", () => {
      if (window.matchMedia("(min-width: 1024.01px)").matches) {
        close();
      }
    });
  });
</script>

<style lang="scss">
  @use "@styles/var" as *;
  @use "@styles/mixin" as *;
  /* ヘッダーの挙動制御 */
  .c-header,
  .c-header--mobile {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: rgba(0, 0, 0, 0.5);

    /* ここ重要：Heroより前に出す */
    z-index: 3000;

    transform: translateY(0);
    transition: transform 260ms ease;

    /* 背景ぼかし（対応ブラウザ） */
    backdrop-filter: blur(3px) saturate(1.1);
    -webkit-backdrop-filter: blur(3px) saturate(1.1);

    /* フォールバック（未対応環境） */
    background-color: rgba(0, 0, 0, 0.75);

    &.is-hidden {
      transform: translateY(-100%);
    }
  }

  /* header bar */
  .c-header--mobile {
    .c-header__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: var(--header-h);
      padding: 0 $container-padding;
    }

    .c-header__logo {
      color: $color-text;
      font-weight: 700;
      text-decoration: none;
      white-space: nowrap;
    }

    .c-header__menuBtn {
      background: none;
      border: 0;
      color: $color-text;
      font-size: 20px;
      padding: 10px;
    }
  }

  .c-drawerOverlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: $z-drawer;

    opacity: 0;
    visibility: hidden;
    pointer-events: none;

    transition: opacity 200ms ease;
  }

  .c-drawerHint {
    position: fixed;
    left: 50%;
    bottom: 16px;
    transform: translateX(-50%);

    width: 22px;
    height: 22px;

    z-index: $z-drawer + 1;
    pointer-events: none; /* overlayタップを妨げない */

    opacity: 0;
    visibility: hidden;
    transition: opacity 160ms ease;
    &::before,
    &::after {
      content: "";
      position: absolute;
      inset: 50% auto auto 50%;

      width: 22px;
      height: 1.5px;

      background: $color-text;
      transform-origin: center;
    }
    &::before {
      transform: translate(-50%, -50%) rotate(45deg);
    }
    &::after {
      transform: translate(-50%, -50%) rotate(-45deg);
    }
  }
  :global(html.is-drawer-open) .c-drawerHint {
    opacity: 0.75;
    visibility: visible;
  }

  .c-drawer {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;

    max-height: calc(100svh - 120px);
    background: $color-bg;
    z-index: $z-drawer + 1;

    transform: translateY(-100%);
    visibility: hidden;
    pointer-events: none;

    transition: transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;

    /* ===== drawer内コンテンツ：遅れてフェード ===== */
    &__inner {
      max-height: calc(100svh - 120px);
      overflow-y: auto;
      padding: 14px 16px 18px;
      opacity: 0;
      transform: translateY(-6px);
      transition:
        opacity 180ms ease,
        transform 180ms ease;

      /* 閉じる時は遅延させない（キビキビ閉じる） */
      transition-delay: 0ms;
    }
    &__nav {
      display: block;
    }
    &__link {
      display: flex;
      align-items: center;
      justify-content: space-between;

      padding: 12px 2px;
      color: $color-text;
      text-decoration: none;

      font-weight: 800;
      letter-spacing: var(--letter-spacing-body, 0);

      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      &:last-child {
        border-bottom: 0;
      }
    }
    &__group {
      padding: 10px 0 6px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);

      &:first-of-type {
        margin-top: 6px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
      }
    }

    &__label {
      display: block;
      padding: 8px 2px 6px;

      font-weight: 900;
      opacity: 0.9;

      letter-spacing: var(--letter-spacing-heading, 0);
    }

    /* サブリンク（インデント＋少し小さく） */
    &__subLink {
      display: block;
      padding: 10px 2px 10px 14px;

      color: $color-text;
      text-decoration: none;

      font-weight: 700;
      opacity: 0.92;

      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    /* 言語切り替えボタン */
    &__lang {
      margin-top: 14px;
      padding-top: 12px;
      border-top: 1px solid rgba(255, 255, 255, 0.08);

      display: flex;
      align-items: center;
      gap: 10px;

      opacity: 0.85;

      display: flex;
      flex-direction: row;
      justify-content: flex-end;
    }

    &__langItem {
      color: $color-text;
      text-decoration: none;
      font-weight: 800;

      &.is-current {
        pointer-events: none;
        opacity: 1;
      }
    }

    &__langSep {
      opacity: 0.4;
    }
  }
  .c-drawer__close {
    display: grid;
    place-items: center;

    width: 44px;
    height: 44px;
    margin: 16px auto 0;

    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: $color-text;

    font-size: 28px;
    line-height: 1;
    cursor: pointer;
  }

  /* open state */
  :global(html.is-drawer-open) .c-drawer {
    transform: translateY(0);
    visibility: visible;
    pointer-events: auto;
  }

  /* body lock（必要最小限） */
  :global(html.is-drawer-open),
  :global(html.is-drawer-open body) {
    overflow: hidden;
  }
  :global(html.is-drawer-open) .c-drawerOverlay {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  /* 中身表示の遅延用 */
  /* 開いた後、少し遅れて出す */
  :global(html.is-drawer-open) .c-drawer__inner {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 120ms;
  }

  /* ===== 三本線のスタイル ===== */
  .c-menuBtn {
    width: 44px;
    height: 44px;
    padding: 0;
    background: none;
    border: 0;
    position: relative;
    cursor: pointer;
    z-index: 999;
  }

  /* 三本線の本体 */
  .c-menuBtn span,
  .c-menuBtn span::before,
  .c-menuBtn span::after {
    content: "";
    position: absolute;
    right: 0px;

    width: 22px;
    height: 2px;
    background: $color-text;
    border-radius: 1px;

    transition:
      width 180ms ease,
      transform 180ms ease,
      opacity 120ms ease;
  }

  /* 中央線 */
  .c-menuBtn span {
    top: 50%;
    transform: translateY(-50%);
  }

  /* 上下線 */
  .c-menuBtn span::before {
    transform: translateY(-7px);
  }
  .c-menuBtn span::after {
    transform: translateY(7px);
  }

  /* 開いている状態 */
  :global(html.is-drawer-open) .c-menuBtn span,
  :global(html.is-drawer-open) .c-menuBtn span::before,
  :global(html.is-drawer-open) .c-menuBtn span::after {
    width: 4px; /* 短くする */
    height: 4px; /* 点にする */
    border-radius: 2px; /* 完全な点 */
    background-color: $color-gray-600;
  }

  /* 縦に3点並べる */
  :global(html.is-drawer-open) .c-menuBtn span {
    transform: translateY(-50%);
  }
  :global(html.is-drawer-open) .c-menuBtn span::before {
    transform: translateY(-10px);
  }
  :global(html.is-drawer-open) .c-menuBtn span::after {
    transform: translateY(10px);
  }
</style>
