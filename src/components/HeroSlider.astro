---
import type { Lang } from "@/locales/multilingual";
import { tHero } from "@/locales/heroSlides.i18n";
import { heroSlides } from "@/components/hero/heroSlides";

const { lang } = Astro.props as { lang: Lang };

// 既存設計に合わせて維持
const scrollTargetId = "home-content";
const SLIDE_MS = 6000;

const slides = heroSlides.map((s) => ({
  ...s,
  html: tHero(lang, s.key) as string,
}));
---

<section
  class="hero"
  aria-label="Hero"
  data-interval={SLIDE_MS}
  data-lottie-src="/assets/lottie/ne-logo-nega.json"
  data-stop-at-end="true"
  data-lottie-freeze-last="true"
>
  <div class="hero__bg" aria-hidden="true"></div>
  <!-- SVGによる背景グラデーション -->
  <svg class="hero__filters" aria-hidden="true" focusable="false">
    <filter id="heroWobble" x="-20%" y="-20%" width="140%" height="140%">
      <!-- ノイズ生成 -->
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.010 0.020"
        numOctaves="2"
        seed="2"
        result="noise"
      >
        <!-- うねり速度：dur を変えると速さが変わる -->
        <animate
          attributeName="baseFrequency"
          dur="12s"
          values="0.010 0.020;0.018 0.010;0.010 0.020"
          repeatCount="indefinite"></animate>
        <animate
          attributeName="seed"
          dur="8s"
          values="2;8;2"
          repeatCount="indefinite"></animate>
      </feTurbulence>

      <!-- 境界の歪み（scale が大きいほど“うねり”が強い） -->
      <feDisplacementMap
        in="SourceGraphic"
        in2="noise"
        scale="28"
        xChannelSelector="R"
        yChannelSelector="G"></feDisplacementMap>
    </filter>
  </svg>

  <div class="hero__inner">
    <div class="hero__copy" data-hero-copy aria-live="polite">
      {
        slides.map((s, i) => (
          <div
            class={`hero__slidecopy ${i === 0 ? "is-active" : ""}`}
            data-hero-slidecopy
            data-slide={s.type}
            data-variant={s.variant}
            aria-hidden={i === 0 ? "false" : "true"}
          >
            <p class={`hero__line ${s.className ?? ""}`} set:html={s.html} />

            {s.type === "lottie" && (
              <div class="hero__lottie" data-hero-lottie aria-hidden="true" />
            )}
          </div>
        ))
      }
    </div>
  </div>
  <a class="hero__scroll" href={`#${scrollTargetId}`} data-hero-scroll>
    <span class="hero__scroll-label">SCROLL</span>
    <!-- <span class="hero__scroll-bar" aria-hidden="true"></span> -->
  </a>
</section>

<script>
  /**
   * Hero slider (6s default, 12s on final lottie slide)
   * - Full replacement version
   * - Uses setTimeout for per-slide duration
   * - Avoids implicit-any warnings via JSDoc types + explicit casts
   */
  (() => {
    /** @type {HTMLElement | null} */
    const root = document.querySelector(".hero");
    if (!root) return;

    /* ------------------------------
     * smooth scroll
     * ------------------------------ */
    /** @type {HTMLAnchorElement | null} */
    const link = root.querySelector("[data-hero-scroll]");
    link?.addEventListener("click", (e) => {
      const href = link.getAttribute("href") || "";
      if (!href.startsWith("#")) return;

      const target = document.getElementById(href.slice(1));
      if (!target) return;

      e.preventDefault();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    /* ------------------------------
     * slides
     * ------------------------------ */
    /** @type {HTMLElement[]} */
    const slides = Array.from(root.querySelectorAll("[data-hero-slidecopy]"));
    if (!slides.length) return;

    const DEFAULT_INTERVAL = Number(root.getAttribute("data-interval")) || 6000;
    const FINAL_INTERVAL = DEFAULT_INTERVAL * 2; // 12s when default is 6s

    let index = 0;

    /** @type {number | null} */
    let timerId = null;

    const reduceMotion =
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    /* ------------------------------
     * lottie
     * ------------------------------ */

    /** @type {any | null} */
    let lottieAnim = null;

    /** @type {Promise<any> | null} */
    let lottieScriptPromise = null;

    /** @param {HTMLElement} el */
    function isFinalSlide(el) {
      // final slide is the lottie slide in your markup
      return el.getAttribute("data-slide") === "lottie";
    }

    function loadLottieScript() {
      if (lottieScriptPromise) return lottieScriptPromise;

      /** @type {any} */
      const w = window;

      if (w.lottie) {
        lottieScriptPromise = Promise.resolve(w.lottie);
        return lottieScriptPromise;
      }

      lottieScriptPromise = new Promise((resolve, reject) => {
        const s = document.createElement("script");
        s.src =
          "https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.12.2/lottie.min.js";
        s.onload = () => resolve(w.lottie);
        s.onerror = (/** @type {Event} */ err) => reject(err);
        document.head.appendChild(s);
      });

      return lottieScriptPromise;
    }

    /** @param {HTMLElement} slideEl */
    async function mountOrPlayLottie(slideEl) {
      /** @type {HTMLElement | null} */
      const box = slideEl.querySelector("[data-hero-lottie]");
      if (!box) return;

      const jsonPath = root.getAttribute("data-lottie-src");
      if (!jsonPath) return;

      try {
        const lottie = await loadLottieScript();
        if (!lottie) return;

        if (!lottieAnim) {
          lottieAnim = lottie.loadAnimation({
            container: box,
            renderer: "svg",
            loop: false,
            autoplay: true,
            path: jsonPath,
          });
        } else {
          // restart from 0 each time we enter final slide
          if (typeof lottieAnim.goToAndPlay === "function") {
            lottieAnim.goToAndPlay(0, true);
          } else if (typeof lottieAnim.play === "function") {
            lottieAnim.play();
          }
        }
      } catch (e) {
        console.error("Lottie load/play failed:", e);
      }
    }

    function stopLottie() {
      try {
        if (lottieAnim && typeof lottieAnim.stop === "function")
          lottieAnim.stop();
      } catch (e) {
        console.error("Lottie stop failed:", e);
      }
    }

    /* ------------------------------
     * slide control (variable duration)
     * ------------------------------ */
    function getCurrentDelay() {
      const curr = slides[index];
      return isFinalSlide(curr) ? FINAL_INTERVAL : DEFAULT_INTERVAL;
    }

    function clearTimer() {
      if (timerId == null) return;
      window.clearTimeout(timerId);
      timerId = null;
    }

    function scheduleNext() {
      clearTimer();
      if (reduceMotion) return;

      const delay = getCurrentDelay();
      timerId = window.setTimeout(() => {
        goNext();
      }, delay);
    }

    /** @param {number} nextIndex */
    function apply(nextIndex) {
      const prev = slides[index];
      prev.classList.remove("is-active");
      prev.setAttribute("aria-hidden", "true");

      if (isFinalSlide(prev)) stopLottie();

      index = nextIndex;

      const curr = slides[index];
      curr.classList.add("is-active");
      curr.setAttribute("aria-hidden", "false");

      if (isFinalSlide(curr)) {
        mountOrPlayLottie(curr);
      }

      scheduleNext();
    }

    function goNext() {
      const n = (index + 1) % slides.length;
      apply(n);
    }

    /* ------------------------------
     * intersection observer
     * ------------------------------ */
    const io = new IntersectionObserver(
      (entries) => {
        const visible = entries.some((e) => e.isIntersecting);
        if (visible) {
          // resume scheduling from "now" based on current slide
          scheduleNext();
        } else {
          clearTimer();
          // optional: stop lottie while offscreen (keeps CPU quiet)
          const curr = slides[index];
          if (isFinalSlide(curr)) stopLottie();
        }
      },
      { threshold: 0.2 }
    );

    io.observe(root);

    /* ------------------------------
     * initial state
     * ------------------------------ */
    slides.forEach((el, i) => {
      el.classList.toggle("is-active", i === 0);
      el.setAttribute("aria-hidden", i === 0 ? "false" : "true");
    });

    // If first slide is lottie (unlikely), mount it.
    if (isFinalSlide(slides[0])) mountOrPlayLottie(slides[0]);

    // Start scheduling immediately if hero is in view
    scheduleNext();
  })();
</script>

<style lang="scss">
  @use "@styles/var" as *;
  @use "@styles/mixin" as *;

  .hero {
    position: relative;
    overflow: hidden;
    height: 100svh;
  }

  .hero__filters {
    position: absolute;
    width: 0;
    height: 0;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background: #000;
    overflow: hidden;

    &::before,
    &::after {
      content: "";
      position: absolute;
      inset: -20%;
      background-size: 220% 220%;
      transform: translateZ(0);
      will-change: background-position, transform, opacity, filter;
    }

    /* レイヤー1：線形グラデーション群（透明度で重ねる） */
    &::before {
      background-image:
        linear-gradient(
          120deg,
          rgba(30, 120, 190, 0.55) 0%,
          rgba(80, 40, 160, 0.45) 35%,
          rgba(140, 20, 84, 0.4) 65%,
          rgba(0, 0, 0, 0) 100%
        ),
        linear-gradient(
          20deg,
          rgba(190, 70, 40, 0.22) 0%,
          rgba(0, 0, 0, 0) 60%
        ),
        linear-gradient(
          180deg,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0.65) 65%,
          rgba(0, 0, 0, 0.95) 100%
        );

      opacity: 0.95;

      /* うねうね＝SVGフィルタで境界を歪ませる */
      filter: url(#heroWobble) saturate(1.15) brightness(0.85);

      animation: heroLinearMove 14s ease-in-out infinite alternate;
    }

    /* レイヤー2：黒への締まり（コントラスト確保） */
    &::after {
      background-image: linear-gradient(
        0deg,
        rgba(0, 0, 0, 0) 0%,
        rgba(0, 0, 0, 0.33) 45%,
        rgba(0, 0, 0, 0.66) 70%,
        rgba(0, 0, 0, 1) 100%
      );
      opacity: 1;
      animation: heroShadeMove 18s ease-in-out infinite alternate;
    }
  }

  @keyframes heroLinearMove {
    0% {
      background-position: 10% 20%;
    }
    50% {
      background-position: 70% 40%;
    }
    100% {
      background-position: 25% 80%;
    }
  }

  @keyframes heroShadeMove {
    0% {
      background-position: 50% 0%;
    }
    100% {
      background-position: 50% 100%;
    }
  }

  /* モーション制限 */
  @media (prefers-reduced-motion: reduce) {
    .hero__bg::before,
    .hero__bg::after {
      animation: none !important;
    }
    .hero__bg::before {
      filter: none !important;
    }
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: 24px;
  }

  .hero__copy {
    position: relative;
    width: min(1100px, 100%);
    min-height: clamp(140px, 24svh, 320px);
    text-align: center;
    color: #fff;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.55);
    display: grid;
    place-items: center;
    text-align: center;
  }

  .hero__slidecopy {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 700ms ease,
      transform 700ms ease;
    pointer-events: none;

    &.is-active {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 英文：添付画像寄せ（セリフ・大きく・字間） */
  .hero__slidecopy[data-variant="en-serif"] .hero__line {
    font-family: "Cormorant Garamond", serif;
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(26px, 4.8vw, 74px);
    line-height: 1;

    color: $color-text;
    text-shadow: 0 10px 40px rgba(0, 0, 0, 0.55);
    white-space: nowrap; /* まずは1行固定（崩れ防止） */
  }
  .hero__slidecopy[data-variant="jp-strong"] .hero__line {
    font-family: "Noto Serif JP", "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-weight: 800;
    font-size: clamp(26px, 4.8vw, 74px);
    letter-spacing: 0.1em;
    line-height: 1.1;
    color: $color-text;
  }

  .hero__slidecopy[data-variant="jp-strong-ml"] .hero__line {
    font-family: "Noto Serif JP", "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-weight: 700;
    font-size: clamp(26px, 4.8vw, 74px);
    letter-spacing: 0.08em;
    line-height: 1.25;
    color: $color-text;
  }
  /* 最終スライド */
  /* ===== Final slide: "生活空間" text ===== */
  .hero__slidecopy[data-variant="jp-logo"] .hero__line {
    font-family:
      system-ui,
      -apple-system,
      "Segoe UI",
      "Hiragino Sans",
      "Noto Sans JP",
      sans-serif;
    font-weight: 600;
    font-size: clamp(24px, 5vw, 56px); /* 他より小さめ */
    letter-spacing: 0.3em; /* 字間広め */
    line-height: 1.2;
    color: #fff;
    text-align: center;
    opacity: 0.95;
  }
  /* ===== Lottie container ===== */
  .hero__slidecopy[data-variant="jp-logo"] .hero__lottie {
    margin-top: 16px;
    width: min(480px, 88vw);
  }

  /* 画面が狭いときだけ折り返し許可（任意） */
  @media (max-width: 520px) {
    .hero__slidecopy[data-variant="en-serif"] .hero__line {
      white-space: normal;
    }
    .hero__slidecopy[data-variant="jp-strong"] .hero__line {
      font-family: "Noto Serif JP", "Yu Mincho", "Hiragino Mincho ProN", serif;
      font-weight: 800;
      font-size: clamp(26px, 4.8vw, 74px);
      letter-spacing: 0.1em;
      line-height: 1.1;
      color: $color-text;
    }

    .hero__slidecopy[data-variant="jp-strong-ml"] .hero__line {
      font-family: "Noto Serif JP", "Yu Mincho", "Hiragino Mincho ProN", serif;
      font-weight: 700;
      font-size: clamp(26px, 4.8vw, 74px);
      letter-spacing: 0.08em;
      line-height: 1.25;
      color: $color-text;
    }
  }

  .hero__lottie {
    margin-top: 14px;
    width: min(400px, 56vw);
  }

  .hero__line {
    margin: 0;
    line-height: 1.25;
    font-size: clamp(16px, 2.2vw, 28px);
    letter-spacing: 0.02em;

    & + & {
      margin-top: 10px;
    }
  }

  .hero__line--en {
    font-size: clamp(22px, 3.2vw, 56px);
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .hero__line--spaced {
    margin-top: 18px;
  }

  .hero__logo-note {
    display: inline-block;
    margin-top: 8px;
    opacity: 0.8;
    font-size: 0.9em;
  }

  .hero__scroll {
    position: absolute;
    left: 16px;
    bottom: 0px;
    z-index: 10;

    display: inline-flex;
    align-items: center;
    gap: 10px;

    color: #fff;
    text-decoration: none;
    opacity: 0.9;

    font-size: 12px;
    letter-spacing: 0.18em;

    &:hover {
      opacity: 1;
    }

    /* 左の縦棒 */
    &::before {
      content: "";
      width: 1px;
      height: 64px;
      background: currentColor;
      display: block;
      transform-origin: bottom;
      animation: heroScrollLine 1.4s ease-in-out infinite;
    }
    /* アニメーション */
    @keyframes heroScrollLine {
      0% {
        transform: scaleY(0.4);
        opacity: 0.3;
      }
      50% {
        transform: scaleY(1);
        opacity: 0.3;
      }
      100% {
        transform: scaleY(0.4);
        opacity: 0.3;
      }
    }
  }
  /* 動きを止める設定をしているユーザーにはアニメーション停止 */
  @media (prefers-reduced-motion: reduce) {
    .hero__scroll::before,
    .hero__scroll::after {
      animation: none !important;
    }
  }

  .hero__scroll-label {
    font-size: 12px;
    letter-spacing: 0.18em;
  }

  .hero__scroll-bar {
    width: 54px;
    height: 1px;
    background: rgba(255, 255, 255, 0.8);
  }

  /* ==============================================================
    SP（md以下）調整
    ============================================================== */
  @include bp-down(md) {
    /* 1) 見た目の中心が下に寄る → ヘッダ分だけ上にオフセット */
    .hero__inner {
      transform: translateY(calc(var(--header-h) * -1));
    }

    /* 2) 行間を少し広げる（全体ベース） */
    .hero__slidecopy .hero__line {
      line-height: 1.35;
    }

    /* 3) 文字サイズUP：和文強調（複数行） */
    .hero__slidecopy[data-variant="jp-strong-ml"] .hero__line,
    .hero__slidecopy[data-variant="jp-strong"] .hero__line {
      font-size: clamp(32px, 7.2vw, 40px);
      letter-spacing: 0em;
      line-height: 1.6;
    }

    /* 4) 文字サイズUP：英文 */
    .hero__slidecopy[data-variant="en-serif"] .hero__line {
      font-size: clamp(48px, 10vw, 54px);
      line-height: 1.4;
      letter-spacing: 0.06em;
    }

    /* 5) 最終「生活空間」：小さめ維持＋行間 */
    .hero__slidecopy[data-variant="jp-logo"] .hero__line {
      font-size: clamp(32px, 7.2vw, 40px);
      line-height: 1.6;
      letter-spacing: 0.28em;
    }
  }
</style>
