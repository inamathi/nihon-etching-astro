---
import { t, type Lang } from "@/locales/multilingual";

const { lang } = Astro.props as { lang: Lang };

type Item = {
  src: string;
  altKey: string;
  titleKey: string;
  descKey: string;
};

const { items = [] } = Astro.props as {
  items: Item[];
};
---

<section class="image-gallery">
  <ul class="image-gallery__list">
    {
      items.map((item) => (
        <li
          class="image-gallery__item"
          data-gallery-item
          data-src={item.src}
          data-alt={t(lang, item.altKey)}
          data-title={t(lang, item.titleKey)}
          data-desc={t(lang, item.descKey)}
        >
          <figure class="image-gallery__figure">
            <div class="image-gallery__media">
              <img
                class="image-gallery__image"
                src={item.src}
                alt={t(lang, item.altKey)}
                loading="lazy"
              />
            </div>

            <figcaption class="image-gallery__caption">
              <dl class="image-gallery__dl">
                <dt class="image-gallery__dt">{t(lang, item.titleKey)}</dt>
                <dd class="image-gallery__dd">{t(lang, item.descKey)}</dd>
              </dl>
            </figcaption>
          </figure>
        </li>
      ))
    }
  </ul>
  <!-- Gallery Modal (SP) -->
  <div class="image-gallery__modal" data-gallery-modal aria-hidden="true">
    <!-- overlay (gallery専用DOM) -->
    <div class="image-gallery__overlay" data-gallery-overlay></div>

    <!-- hint (×印：見た目は .c-drawerHint と同一) -->
    <div class="image-gallery__hint" aria-hidden="true"></div>

    <!-- panel -->
    <div
      class="image-gallery__modal-panel"
      role="dialog"
      aria-modal="true"
      aria-label="Image detail"
    >
      <div class="image-gallery__modal-media">
        <img class="image-gallery__modal-img" data-gallery-modal-img alt="" />
      </div>

      <div class="image-gallery__modal-caption">
        <dl class="image-gallery__dl">
          <dt class="image-gallery__dt" data-gallery-modal-title></dt>
          <dd class="image-gallery__dd" data-gallery-modal-desc></dd>
        </dl>
      </div>
    </div>
  </div>
</section>

<!-- Blur用スクリプト -->
<script>
  (() => {
    const roots = Array.from(document.querySelectorAll(".image-gallery"));
    if (!roots.length) return;

    const isDesktop = () => window.matchMedia("(min-width: 768px)").matches;

    roots.forEach((root) => {
      const items = Array.from(root.querySelectorAll("[data-gallery-item]"));
      if (!items.length) return;

      function clearActive() {
        root.classList.remove("is-dimming");
        items.forEach((el) => el.classList.remove("is-active"));
      }

      items.forEach((el) => {
        el.addEventListener("mouseenter", () => {
          if (!isDesktop()) return;
          root.classList.add("is-dimming");
          items.forEach((x) => x.classList.toggle("is-active", x === el));
        });

        el.addEventListener("mouseleave", () => {
          if (!isDesktop()) return;
          clearActive();
        });
      });

      window.addEventListener("resize", () => {
        if (!isDesktop()) clearActive();
      });
    });
  })();
</script>

<!-- SPモーダル用 -->
<script>
  (() => {
    const roots = Array.from(document.querySelectorAll(".image-gallery"));
    if (!roots.length) return;

    const isSP = () => window.matchMedia("(max-width: 767.98px)").matches;

    // ---- scroll lock (jump-safe) ----
    let savedScrollY = 0;
    function lockScroll() {
      savedScrollY = window.scrollY || window.pageYOffset || 0;
      document.body.classList.add("is-scroll-locked");
      document.body.style.top = `-${savedScrollY}px`;
    }
    function unlockScroll() {
      document.body.classList.remove("is-scroll-locked");
      const top = document.body.style.top;
      document.body.style.top = "";
      const y = top ? Math.abs(parseInt(top, 10)) : savedScrollY;
      window.scrollTo(0, y);
    }

    roots.forEach((root) => {
      const modal = root.querySelector("[data-gallery-modal]");
      if (!modal) return;

      const overlay = modal.querySelector("[data-gallery-overlay]");
      const modalImg = modal.querySelector("[data-gallery-modal-img]");
      const modalTitle = modal.querySelector("[data-gallery-modal-title]");
      const modalDesc = modal.querySelector("[data-gallery-modal-desc]");

      function openModalFromItem(itemEl) {
        if (!isSP()) return;

        const src = itemEl.getAttribute("data-src") || "";
        const alt = itemEl.getAttribute("data-alt") || "";
        const title = itemEl.getAttribute("data-title") || "";
        const desc = itemEl.getAttribute("data-desc") || "";

        if (modalImg) {
          modalImg.setAttribute("src", src);
          modalImg.setAttribute("alt", alt);
        }
        if (modalTitle) modalTitle.textContent = title;
        if (modalDesc) modalDesc.textContent = desc;

        modal.setAttribute("aria-hidden", "false");
        lockScroll();
      }

      function closeModal() {
        modal.setAttribute("aria-hidden", "true");

        if (modalImg) {
          modalImg.removeAttribute("src");
          modalImg.setAttribute("alt", "");
        }
        if (modalTitle) modalTitle.textContent = "";
        if (modalDesc) modalDesc.textContent = "";

        unlockScroll();
      }

      // ---- open: event delegation (SP only) ----
      root.addEventListener(
        "click",
        (e) => {
          if (!isSP()) return;

          const target = e.target;
          if (!(target instanceof Element)) return;

          const item = target.closest("[data-gallery-item]");
          if (!item || !root.contains(item)) return;

          e.preventDefault();
          e.stopPropagation();
          if (typeof e.stopImmediatePropagation === "function") {
            e.stopImmediatePropagation();
          }

          openModalFromItem(item);
        },
        true
      );

      // ---- close: overlay tap ----
      overlay?.addEventListener("click", (e) => {
        if (!isSP()) return;
        e.preventDefault();
        closeModal();
      });

      // ---- ESC close ----
      window.addEventListener("keydown", (e) => {
        if (e.key !== "Escape") return;
        if (modal.getAttribute("aria-hidden") === "false") closeModal();
      });

      // ---- resize cleanup ----
      window.addEventListener("resize", () => {
        if (!isSP() && modal.getAttribute("aria-hidden") === "false")
          closeModal();
      });
    });
  })();
</script>

<style lang="scss">
  @use "@styles/var" as *;
  @use "@styles/mixin" as *;
  @use "@styles/font" as *;

  .image-gallery {
    width: 100%;
    padding: 0 0 40px;
  }

  /* =========================
     list / item
     ========================= */

  .image-gallery__list {
    display: block;

    column-gap: 10px;
    columns: 4;

    margin: 0;
    padding: 0;
    list-style: none;
  }

  @include bp-down(sm) {
    .image-gallery__list {
      columns: 2;
    }
  }

  .image-gallery__item {
    /* column内で分割されないように */
    break-inside: avoid;
    -webkit-column-break-inside: avoid;

    /* gapの代わりに下マージン */
    margin: 0 0 10px;
  }

  /* =========================
     figure / image
     ========================= */

  .image-gallery__figure {
    position: relative; /* absolute caption の基準 */
    margin: 0;
  }

  /* 画像枠：丸角・はみ出し制御はここ */
  .image-gallery__media {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.04);
  }

  /* 画像：hoverで拡大する対象 */
  .image-gallery__image {
    display: block;
    width: 100%;
    height: auto;

    transform: scale(1);
    transition: transform 260ms ease;
    will-change: transform;
  }

  /* =========================
     caption（黒帯＋テキスト）
     ========================= */

  .image-gallery__caption {
    position: absolute;
    left: 0;
    right: 0;

    /* 画像（media）の直下に出す */
    top: calc(100% + 0px);

    background: rgba(0, 0, 0, 0.62);
    border-radius: 4px;
    padding: 12px 14px;

    color: #fff;

    /* レイアウト領域を取らない（= ここが重要） */
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;

    transition:
      opacity 220ms ease,
      transform 220ms ease;

    /* 文章量が多い前提で最低限の見切れ対策 */
    max-height: 220px;
    overflow: hidden;
  }

  /* dlの見た目 */
  .image-gallery__dl {
    margin: 0;
  }

  .image-gallery__dt {
    margin: 0 0 6px;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.02em;
    line-height: 1.3;
  }

  .image-gallery__dd {
    margin: 0;
    font-size: 12.5px;
    line-height: 1.6;
    opacity: 0.92;
  }

  /* =========================
     Desktop hover
     ========================= */

  /* Desktop hover */
  @include bp-up(md) {
    .image-gallery__item {
      position: relative;
      z-index: 0;
    }

    .image-gallery__item:hover {
      z-index: 50; /* 他画像より前へ（被せる） */
    }

    .image-gallery__item:hover .image-gallery__image {
      transform: scale(1.08);
      transform-origin: 50% 50%;
    }

    .image-gallery__item:hover .image-gallery__caption {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
  }

  /* SP：いったん非表示（モーダルで出す想定ならこれが安全） */
  @include bp-down(md) {
    .image-gallery__caption {
      display: none;
    }
  }

  /* =========================
   Dimming / blur (PC only)
   ========================= */

  @include bp-up(md) {
    /* ぼかし対象の画像（hover中以外） */
    .image-gallery.is-dimming .image-gallery__item .image-gallery__media {
      filter: blur(3px);
      opacity: 0.55;
      transition:
        filter 180ms ease,
        opacity 180ms ease;
    }

    /* hover中の1枚は通常表示 */
    .image-gallery.is-dimming
      .image-gallery__item.is-active
      .image-gallery__media {
      filter: none;
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .image-gallery__media {
      transition: none !important;
    }
  }

  /* =========================
   Gallery Modal (SP)
   ========================= */

  .image-gallery__modal {
    position: fixed;
    inset: 0;
    z-index: $z-drawer;

    /* display切替ではなく、常駐＋操作不能で隠す */
    opacity: 0;
    visibility: hidden;
    pointer-events: none;

    transition:
      opacity 200ms ease,
      visibility 0s linear 200ms;
  }

  .image-gallery__modal[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;

    transition:
      opacity 200ms ease,
      visibility 0s;
  }
  /* overlay: .c-drawerOverlay と同じ見た目 */
  .image-gallery__overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: $z-drawer;

    opacity: 0;
    visibility: hidden;
    pointer-events: none;

    transition: opacity 200ms ease;

    /* === 追加：背景ぼかし === */
    backdrop-filter: blur(6px) saturate(0.9);
    -webkit-backdrop-filter: blur(6px) saturate(0.9);
  }

  /* hint: .c-drawerHint と同じ見た目（画面下中央） */
  .image-gallery__hint {
    position: fixed;
    left: 50%;
    bottom: 16px;
    transform: translateX(-50%);

    width: 22px;
    height: 22px;

    z-index: $z-drawer + 1;
    pointer-events: none; /* overlayタップを妨げない */

    opacity: 0;
    visibility: hidden;
    transition: opacity 160ms ease;

    &::before,
    &::after {
      content: "";
      position: absolute;
      inset: 50% auto auto 50%;
      width: 22px;
      height: 1.5px;
      background: $color-text;
      transform-origin: center;
    }
    &::before {
      transform: translate(-50%, -50%) rotate(45deg);
    }
    &::after {
      transform: translate(-50%, -50%) rotate(-45deg);
    }
  }

  /* open時に表示 */
  .image-gallery__modal[aria-hidden="false"] .image-gallery__overlay {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .image-gallery__modal[aria-hidden="false"] .image-gallery__hint {
    opacity: 1;
    visibility: visible;
  }

  /* panel */
  .image-gallery__modal-panel {
    position: fixed;
    left: 50%;
    top: 50%;
    opacity: 0;
    transform: translate(-50%, -48%) scale(0.98);
    transition:
      opacity 220ms ease,
      transform 220ms ease;
    will-change: opacity, transform;

    z-index: $z-drawer + 2; /* hintより前でもOK。好みで +1 に */

    width: min(92vw, 560px);
    max-height: min(82svh, 780px);
    overflow: auto;

    border-radius: 14px;
    background: rgba(12, 12, 12, 0.92);
    color: #fff;
    padding: 14px;
  }

  .image-gallery__modal[aria-hidden="false"] .image-gallery__modal-panel {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .image-gallery__modal-media {
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
  }

  .image-gallery__modal-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .image-gallery__modal-caption {
    margin-top: 12px;
    // background: rgba(0, 0, 0, 0.55);
    border-radius: 12px;
    padding: 12px 14px;
  }

  /* 背景スクロール停止 */
  //   html.is-gallery-modal-open,
  //   html.is-gallery-modal-open body {
  //     overflow: hidden;
  //   }

  /* scroll lock: iOS等でトップジャンプしない方式（上記修正版）*/
  body.is-scroll-locked {
    position: fixed;
    left: 0;
    right: 0;
    width: 100%;
  }

  /* PCではモーダル自体不要 */
  @include bp-up(md) {
    .image-gallery__modal {
      display: none !important;
    }
  }

  /* =========================
     motion reduce
     ========================= */

  @media (prefers-reduced-motion: reduce) {
    .image-gallery__image,
    .image-gallery__caption,
    .image-gallery__modal,
    .image-gallery__overlay,
    .image-gallery__modal-panel,
    .image-gallery__hint {
      transition: none !important;
    }
  }
</style>
