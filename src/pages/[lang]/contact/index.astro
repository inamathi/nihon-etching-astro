---
import Base from "@/layouts/Base.astro";
import ContactForm from "@/components/form/ContactForm.astro";
import { t, toLang, type Lang } from "@/locales/multilingual";
import PageHeader from "@/components/ui/PageHeader.astro";
import Breadcrumb from "@/components/common/BreadCrumb.astro";
import Introduction from "@/components/common/Introduction.astro";

export const getStaticPaths = () => [
  { params: { lang: "ja" } },
  { params: { lang: "en" } },
];

const lang: Lang = toLang(Astro.params.lang);
const baseRoot = import.meta.env.BASE_URL.replace(/\/$/, "");
const basePath = `${baseRoot}/${lang}`;

const FORM_ACTION = "https://formspree.io/f/mykkkzgb";
---

<Base lang={lang} title="Contact">
  <PageHeader
    eyebrowText="CONTACT"
    title={t(lang, "contact.page.title")}
    lead={t(lang, "contact.page.lead")}
    imageSrc="/images/pageHeader/pageheader-contact.webp"
    imageAlt={t(lang, "group.listpage.title")}
  />

  <Breadcrumb
    items={[
      { label: t(lang, "nav.top"), href: `${basePath}/` },
      { label: t(lang, "nav.contact"), href: `${basePath}/contact/` },
    ]}
  />
  <main class="l-container">
    <!-- Intro -->
    <Introduction lang={lang} arrayKey="contact.body.intro.paragraphs" />
    <p class="c-contactForm__note c-contactForm__field--full">
      {t(lang, "contact.form.requiredNote")}
    </p>
    <ContactForm lang={lang} basePath={basePath} action={FORM_ACTION} />
  </main>
</Base>

<style lang="scss">
  @use "@styles/var" as *;
  @use "@styles/mixin" as *;
  .c-introduction {
    border: solid 1px $color-gray-600;
    padding: 20px;
    margin: 40px auto 10px;

    display: flex;
    flex-direction: column;
    gap: 5px;
    p {
      color: $color-text;
      padding: 0;
      margin: 0;
    }
  }
</style>
