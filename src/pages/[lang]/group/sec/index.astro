---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import Breadcrumb from "@/components/common/BreadCrumb.astro";
import GroupRegionList from "@/components/group/GroupRegionList.astro";
import { t, toLang, type Lang } from "@/locales/multilingual";
import { companies } from "@/data/companyOverview";
import { makeFields } from "@/lib/companyCards";
import { FIELD_PRESET } from "@/lib/companyFieldPresets";
import type { SecRegionKey } from "@/types/group";
import GroupSideNav from "@/components/group/GroupSideNav.astro";
import HashSmoothScroll from "@/components/group/HashSmoothScroll.astro";

import "@/styles/group/_group-index.scss";

export const getStaticPaths = () => [
  { params: { lang: "ja" } },
  { params: { lang: "en" } },
];

const lang: Lang = toLang(Astro.params.lang);
const baseRoot = import.meta.env.BASE_URL.replace(/\/$/, "");
const basePath = `${baseRoot}/${lang}`;

// SEC抽出
const secCompanies = companies.filter((c) => c.group === "sec");
const fields = makeFields(FIELD_PRESET.sec);

const regionOrder: SecRegionKey[] = [
  "europe",
  "north-america",
  "south-america",
] as const satisfies readonly SecRegionKey[];

const headingKeyMap: Record<SecRegionKey, string> = {
  europe: "common.groupName.secEurope",
  "north-america": "common.groupName.secNorthAmerica",
  "south-america": "common.groupName.secSouthAmerica",
};

const secSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `https://nihon-etching.co.jp/${lang}/group/sec/`,
  name: t(lang, "common.groupName.sec"),
  description: t(lang, "group.sec.lead"),
  url: `https://nihon-etching.co.jp/${lang}/group/sec/`,
  inLanguage: lang,
  isPartOf: {
    "@type": "WebSite",
    url: "https://nihon-etching.co.jp/",
  },
  about: {
    "@type": "Organization",
    "@id": "https://nihon-etching.co.jp/#localbusiness",
    name: "株式会社日本エッチング",
  },
};
---

<Base lang={lang} title={t(lang, "pageTitle.group.sec")}>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(secSchema)}
    slot="head"
  />
  <PageHeader
    eyebrowText="Group"
    title={t(lang, "common.groupName.sec")}
    lead={t(lang, "group.sec.lead")}
    imageSrc="/images/pageHeader/pageheader-group.webp"
    imageAlt={t(lang, "common.groupName.sec")}
  />

  <div class="l-container p-group">
    <Breadcrumb
      items={[
        { label: t(lang, "nav.top"), href: `${basePath}/` },
        { label: t(lang, "nav.group"), href: `${basePath}/group/` },
        { label: t(lang, "nav.group_sec"), href: `${basePath}/group/sec/` },
      ]}
    />
    <section class="l-wrapper">
      <GroupRegionList
        group="sec"
        lang={lang}
        companies={secCompanies}
        fields={fields}
        regionOrder={regionOrder}
        headingKeyMap={headingKeyMap}
      />
      <GroupSideNav lang={lang} basePath={basePath} currentGroup="sec" />
    </section>
    <!-- 遷移してきたときにhashを持っていたらSmoothScroll -->
    <HashSmoothScroll offset={92} />
  </div>
</Base>
