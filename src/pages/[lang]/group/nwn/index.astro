---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import Breadcrumb from "@/components/common/BreadCrumb.astro";
import GroupRegionList from "@/components/group/GroupRegionList.astro";

import { t, toLang, type Lang } from "@/locales/multilingual";
import { companies } from "@/data/companyOverview";
import { makeFields } from "@/lib/companyCards";
import { FIELD_PRESET } from "@/lib/companyFieldPresets";
import type { NwnRegionKey } from "@/types/group";

import GroupSideNav from "@/components/group/GroupSideNav.astro";
import HashSmoothScroll from "@/components/group/HashSmoothScroll.astro";

import "@/styles/group/_group-index.scss";

export const getStaticPaths = () => [
  { params: { lang: "ja" } },
  { params: { lang: "en" } },
];

const lang: Lang = toLang(Astro.params.lang);
const baseRoot = import.meta.env.BASE_URL.replace(/\/$/, "");
const basePath = `${baseRoot}/${lang}`;

// NWN抽出
const nwnCompanies = companies.filter((c) => c.group === "nwn");
const fields = makeFields(FIELD_PRESET.nwn);

const regionOrder: NwnRegionKey[] = [
  "japan",
  "overseas",
  "east-asia",
] as const satisfies readonly NwnRegionKey[];

const headingKeyMap: Record<NwnRegionKey, string> = {
  japan: "common.groupName.nwnJapan",
  overseas: "common.groupName.nwnOverseas",
  "east-asia": "common.groupName.nwnEastAsia",
};

const nwnSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `https://nihon-etching.co.jp/${lang}/group/nwn/`,
  name: t(lang, "common.groupName.nwn"),
  description: t(lang, "group.nwn.lead"),
  url: `https://nihon-etching.co.jp/${lang}/group/nwn/`,
  inLanguage: lang,
  isPartOf: {
    "@type": "WebSite",
    url: "https://nihon-etching.co.jp/",
  },
  about: {
    "@type": "Organization",
    "@id": "https://nihon-etching.co.jp/#localbusiness",
    name: "株式会社日本エッチング",
  },
};
---

<Base lang={lang} title={t(lang, "pageTitle.group.nwn")}>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(nwnSchema)}
    slot="head"
  />
  <PageHeader
    eyebrowText="Group"
    title={t(lang, "common.groupName.nwn")}
    lead={t(lang, "group.nwn.lead")}
    imageSrc="/images/pageHeader/pageheader-group.webp"
    imageAlt={t(lang, "common.groupName.nwn")}
  />

  <div class="l-container p-group">
    <Breadcrumb
      items={[
        { label: t(lang, "nav.top"), href: `${basePath}/` },
        { label: t(lang, "nav.group"), href: `${basePath}/group/` },
        { label: t(lang, "nav.group_nwn"), href: `${basePath}/group/nwn/` },
      ]}
    />
    <section class="l-wrapper">
      <GroupRegionList
        group="nwn"
        lang={lang}
        companies={nwnCompanies}
        fields={fields}
        regionOrder={regionOrder}
        headingKeyMap={headingKeyMap}
      />
      <GroupSideNav lang={lang} basePath={basePath} currentGroup="nwn" />
    </section>
    <!-- 遷移してきたときにhashを持っていたらSmoothScroll -->
    <HashSmoothScroll offset={92} />
  </div>
</Base>
