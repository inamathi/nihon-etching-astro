---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import Breadcrumb from "@/components/common/BreadCrumb.astro";
import PageSectionHeading from "@/components/ui/PageSectionHeading.astro";
import Introduction from "@/components/common/Introduction.astro";
import PdfViewer from "@/components/common/PdfViewer.astro";
import BlockHeading from "@/components/ui/BlockHeading.astro";

import { t, toLang, type Lang } from "@/locales/multilingual";

import "@/styles/technology/_technology-index.scss";

export const getStaticPaths = () => [
  { params: { lang: "ja" } },
  { params: { lang: "en" } },
];

const lang: Lang = toLang(Astro.params.lang);

const baseRoot = import.meta.env.BASE_URL.replace(/\/$/, "");
const basePath = `${baseRoot}/${lang}`;

/* =====================================================
 * Assets（言語非依存：FrontMatterに値を書く）
 * ===================================================== */
// 画像（本文内の画像）
const imageSrc = "/images/technology/laser/img-laser__gfms-ls2500.webp";
console.log("imageSrc", imageSrc);

// PageHeader 用の画像
const heroImage = "/images/pageHeader/pageheader-laser.webp";

// YouTube
const youtubeId = "1LDWVKO9Ztw";
const youtubeSrc = `https://www.youtube-nocookie.com/embed/${youtubeId}?rel=0&modestbranding=1`;

// PDF（タイトルだけ多言語にしたい場合は multilingual.ts にキーを用意して t() で読む）
type PdfItem = {
  titleKey: string; // multilingual.ts のキー
  src: string;
};

const pdfs: PdfItem[] = [
  {
    titleKey: "technology.laser.assets.pdf01",
    src: "/pdf/5axis_laser-2511.pdf",
  },
];

/* =====================================================
 * Gallery（shibo からそのまま移植）
 * ===================================================== */
type GalleryItem = {
  src: string;
  captionKey: string;
};

const laserGallery: GalleryItem[] = [
  {
    src: "/images/technology/laser/img-laser-pattern-01.webp",
    captionKey: "technology.laser.body.gallery.cap01",
  },
  {
    src: "/images/technology/laser/img-laser-pattern-02.webp",
    captionKey: "technology.laser.body.gallery.cap02",
  },
  {
    src: "/images/technology/laser/img-laser-pattern-03.webp",
    captionKey: "technology.laser.body.gallery.cap03",
  },
  {
    src: "/images/technology/laser/img-laser-pattern-04.webp",
    captionKey: "technology.laser.body.gallery.cap04",
  },
  {
    src: "/images/technology/laser/img-laser-pattern-05.webp",
    captionKey: "technology.laser.body.gallery.cap05",
  },
  {
    src: "/images/technology/laser/img-laser-pattern-06.webp",
    captionKey: "technology.laser.body.gallery.cap06",
  },
];

const title = t(lang, "pageTitle.technology.laser");

const laserSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `https://nihon-etching.co.jp/${lang}/technology/laser/`,
  name: t(lang, "technology.laser.page.title"),
  description: t(lang, "technology.laser.page.lead"),
  url: `https://nihon-etching.co.jp/${lang}/technology/laser/`,
  inLanguage: lang,
  provider: {
    "@type": "Organization",
    "@id": "https://nihon-etching.co.jp/#localbusiness",
    name: "株式会社日本エッチング",
  },
  serviceType: "5軸レーザー加工",
  areaServed: {
    "@type": "Country",
    name: "Japan",
  },
};
---

<Base
  lang={lang}
  title={title}
  description={t(lang, "meta.description.technology.laser")}
  ogImage="/ogp/ogp_technology.webp"
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(laserSchema)}
    slot="head"
  />
  <PageHeader
    eyebrowText="TECHNOLOGY"
    title={t(lang, "technology.laser.page.title")}
    lead={t(lang, "technology.laser.page.lead")}
    imageSrc={heroImage}
    imageAlt={t(lang, "technology.laser.assets.imageAlt")}
  />

  <div class="l-container p-technology">
    <Breadcrumb
      ariaLabel={lang === "ja" ? "パンくずリスト" : "Breadcrumb"}
      items={[
        { label: t(lang, "nav.top"), href: `${basePath}/` },
        { label: t(lang, "nav.technology"), href: `${basePath}/technology/` },
        { label: t(lang, "technology.laser.page.title") },
      ]}
    />
    <!-- Intro -->
    <Introduction
      lang={lang}
      arrayKey="technology.laser.body.intro.paragraphs"
    />

    <!-- Image -->
    <section class="l-section">
      <PageSectionHeading text={t(lang, "technology.laser.body.imageTitle")} />
      <div class="p-laser__media">
        <figure class="p-laser__figure">
          <img
            class="p-laser__img"
            src={imageSrc}
            alt={t(lang, "technology.laser.assets.imageAlt")}
            loading="lazy"
            decoding="async"
          />
        </figure>
        <div class="c-techIntro__box c-techIntro__box--compact">
          {
            (t(lang, "technology.laser.body.description") as string[]).map(
              (p) => <p class="c-techIntro__text">{p}</p>,
            )
          }
        </div>
      </div>
      <BlockHeading text={t(lang, "technology.laser.body.featuresTitle")} />
      <ul class="p-laser__features">
        {
          (t(lang, "technology.laser.body.features") as string[]).map((txt) => (
            <li class="p-laser__featureItem" set:html={txt} />
          ))
        }
      </ul>
    </section>

    <!-- YouTube -->
    <section class="l-section">
      <BlockHeading text={t(lang, "technology.laser.body.youtubeTitle")} />
      <section class="p-laser__media">
        <div class="p-laser__youtube" aria-label="youtube">
          <iframe
            class="p-laser__youtubeFrame"
            src={youtubeSrc}
            title={t(lang, "technology.laser.page.title")}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen></iframe>
        </div>
      </section>
    </section>

    <!-- PDF -->
    <section class="l-section">
      <BlockHeading text={t(lang, "technology.laser.body.pdfTitle")} />
      <section class="p-laser__pdf">
        {
          pdfs.map((item) => (
            <div class="p-laser__pdfItem">
              <PdfViewer src={item.src} />
            </div>
          ))
        }
      </section>
    </section>

    <!-- Gallery -->
    <section class="l-section">
      <BlockHeading text={t(lang, "technology.laser.body.galleryTitle")} />
      <div class="c-techGallery" aria-label="laser gallery">
        {
          laserGallery.map((item) => (
            <figure class="c-techGallery__item">
              <img
                class="c-techGallery__img"
                src={item.src}
                alt=""
                loading="lazy"
                decoding="async"
              />
              <figcaption class="c-techGallery__cap">
                {t(lang, item.captionKey)}
              </figcaption>
            </figure>
          ))
        }
      </div>
    </section>
  </div>
</Base>
