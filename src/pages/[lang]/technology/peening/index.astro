---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import Breadcrumb from "@/components/common/BreadCrumb.astro";
import PageSectionHeading from "@/components/ui/PageSectionHeading.astro";
import Introduction from "@/components/common/Introduction.astro";
import BlockHeading from "@/components/ui/BlockHeading.astro";

import { t, toLang, type Lang } from "@/locales/multilingual";
import LinkButton from "@/components/ui/LinkButton.astro";

export const getStaticPaths = () => [
  { params: { lang: "ja" } },
  { params: { lang: "en" } },
];

const lang: Lang = toLang(Astro.params.lang);

const baseRoot = import.meta.env.BASE_URL.replace(/\/$/, "");
const basePath = `${baseRoot}/${lang}`;

/* =====================================================
 * Assets（言語非依存：FrontMatterに値を書く）
 * ===================================================== */
// 画像（本文内の画像）
const imageSrc01 = "/images/technology/peening/img-peening-image01.webp";
const imageSrc02 = "/images/technology/peening/img-peening-image02.webp";

// PageHeader 用の画像
const heroImage = "/images/pageHeader/pageheader-peening.webp";

/* =====================================================
 * Gallery（shibo からそのまま移植）
 * ===================================================== */
type GalleryItem = {
  src: string;
  captionKey: string;
};

const peeningGallery: GalleryItem[] = [
  {
    src: "/images/technology/peening/img-peening-pattern-01.webp",
    captionKey: "technology.peening.body.gallery.cap01",
  },
  {
    src: "/images/technology/peening/img-peening-pattern-02.webp",
    captionKey: "technology.peening.body.gallery.cap02",
  },
];

/* =========================
 * Link Buttons（実体）
 * ========================= */
type LinkItem = {
  href: string;
  labelKeyIndex: number; // multilingual.ts の buttons 配列 index
  target?: "_self" | "_blank";
};

const linkButtons: LinkItem[] = [
  {
    href: "https://plastron.co.jp/",
    labelKeyIndex: 0,
    target: "_blank",
  },
];

const title = t(lang, "pageTitle.technology.peening");

const peeningSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `https://nihon-etching.co.jp/${lang}/technology/peening/`,
  name: t(lang, "technology.peening.page.title"),
  description: t(lang, "technology.peening.page.lead"),
  url: `https://nihon-etching.co.jp/${lang}/technology/peening/`,
  inLanguage: lang,
  provider: {
    "@type": "Organization",
    "@id": "https://nihon-etching.co.jp/#localbusiness",
    name: "株式会社日本エッチング",
  },
  serviceType: "ピーニング加工",
  areaServed: {
    "@type": "Country",
    name: "Japan",
  },
};
---

<Base
  lang={lang}
  title={title}
  description={t(lang, "meta.description.technology.peening")}
  ogImage="/ogp/ogp_technology.webp"
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(peeningSchema)}
    slot="head"
  />
  <PageHeader
    eyebrowText="TECHNOLOGY"
    title={t(lang, "technology.peening.page.title")}
    lead={t(lang, "technology.peening.page.lead")}
    imageSrc={heroImage}
    imageAlt={t(lang, "technology.peening.assets.imageAlt")}
  />

  <div class="l-container p-technology">
    <Breadcrumb
      ariaLabel={lang === "ja" ? "パンくずリスト" : "Breadcrumb"}
      items={[
        { label: t(lang, "nav.top"), href: `${basePath}/` },
        { label: t(lang, "nav.technology"), href: `${basePath}/technology/` },
        { label: t(lang, "technology.peening.page.title") },
      ]}
    />
    <!-- Intro -->
    <Introduction
      lang={lang}
      arrayKey="technology.peening.body.intro.paragraphs"
    />

    <!-- Image -->
    <section class="l-section">
      <PageSectionHeading
        text={t(lang, "technology.peening.body.imageTitle")}
      />
      <div class="p-peening__media">
        <figure class="p-peening__figure">
          <img
            class="p-peening__img"
            src={imageSrc01}
            alt={t(lang, "technology.peening.assets.imageAlt")}
            loading="lazy"
            decoding="async"
          />
        </figure>
        <figure class="p-peening__figure">
          <img
            class="p-peening__img"
            src={imageSrc02}
            alt={t(lang, "technology.peening.assets.imageAlt")}
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
      <BlockHeading text={t(lang, "technology.peening.body.featuresTitle")} />
      <ul class="p-peening__features">
        {
          (t(lang, "technology.peening.body.features") as string[]).map(
            (txt) => <li class="p-peening__featureItem" set:html={txt} />,
          )
        }
      </ul>
    </section>
    <section class="l-section">
      <BlockHeading text={t(lang, "technology.peening.body.link.heading")} />
      <div class="p-peening__linkList">
        {
          linkButtons.map((item) => (
            <LinkButton
              href={item.href}
              target={item.target}
              variant="secondary"
            >
              <span
                set:html={t(
                  lang,
                  `technology.peening.body.link.buttons.${item.labelKeyIndex}.label`,
                )}
              />
            </LinkButton>
          ))
        }
      </div>
    </section>
  </div>
</Base>
