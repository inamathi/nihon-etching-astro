---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import Breadcrumb from "@/components/common/BreadCrumb.astro";
import PageSectionHeading from "@/components/ui/PageSectionHeading.astro";
import Introduction from "@/components/common/Introduction.astro";

import { t, toLang, type Lang, getList } from "@/locales/multilingual";
import LinkButton from "@/components/ui/LinkButton.astro";
import BlockHeading from "@/components/ui/BlockHeading.astro";

export const getStaticPaths = () => [
  { params: { lang: "ja" } },
  { params: { lang: "en" } },
];

const lang: Lang = toLang(Astro.params.lang);
const baseRoot = import.meta.env.BASE_URL.replace(/\/$/, "");
const basePath = `${baseRoot}/${lang}`;

/* =========================
 * Link Buttons（実体）
 * ========================= */
type LinkItem = {
  href: string;
  labelKeyIndex: number; // multilingual.ts の buttons 配列 index
  target?: "_self" | "_blank";
};

const linkButtons: LinkItem[] = [
  {
    href: "https://plastron.co.jp/",
    labelKeyIndex: 0,
    target: "_blank",
  },
];
const title = t(lang, "pageTitle.download");

type PrivacyPolicy = {
  index: Record<string, string>;
  body: Record<string, string>;
};

const privacyPolicy = getList(
  "privacyPolicy.body.paragraphs",
) as PrivacyPolicy[];
---

<Base lang={lang} title={title}>
  <PageHeader
    eyebrowText="PRIVACY POLICY"
    title={t(lang, "pageTitle.privacypolicy")}
    lead={t(lang, "privacyPolicy.page.lead")}
    imageSrc="/images/pageHeader/pageheader-privacy.webp"
    imageAlt={t(lang, "privacyPolicy.page.imageAlt")}
  />

  <main class="l-container">
    <Breadcrumb
      items={[
        { label: t(lang, "nav.top"), href: `${basePath}/` },
        {
          label: t(lang, "nav.privacypolicy"),
          href: `${basePath}/privacypolicy/`,
        },
      ]}
    />
    <section class="p-privacypolicy">
      <BlockHeading text={t(lang, "privacyPolicy.page.title")} />
      <dl class="p-privacypolicy-paragraph">
        {
          privacyPolicy.map((p) => (
            <div>
              <dt>{p.index[lang]}</dt>
              <dd>{p.body[lang]}</dd>
            </div>
          ))
        }
      </dl>
      <dl class="p-privacypolicy-frameblock">
        <div>
          <dt>{t(lang, "privacyPolicy.body.contact.index")}</dt>
          <dd>
            <span>
              {t(lang, "privacyPolicy.body.contact.phone")}
            </span>
            <span>
              {t(lang, "privacyPolicy.body.contact.fax")}
            </span>
          </dd>
        </div>
        <div>
          <dt>{t(lang, "privacyPolicy.body.charge.index")}</dt>
          <dd>
            <span>
              {t(lang, "privacyPolicy.body.charge.value")}
            </span>
          </dd>
        </div>
      </dl>
      <div></div>
    </section>
  </main>
</Base>

<style lang="scss">
  @use "@styles/var" as *;
  @use "@styles/mixin" as *;
  .p-privacypolicy {
    margin: 40px auto;
  }
  .p-privacypolicy-paragraph {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin: 40px auto;
    div {
      display: flex;
      flex-direction: column;
      gap: 2px;
      dt {
        display: inline;
        width: max-content;
        font-size: $fs-m;
        font-weight: bold;
        border-bottom: dotted 2px $color-gray-600;
        padding-bottom: 2px;
      }
      dd {
        font-size: $fs-m;
        font-weight: 300;
      }
    }
  }
  .p-privacypolicy-frameblock {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border: solid 1px $color-gray-600;
    padding: 20px;
    border-radius: 8px;
    width: max-content;
    div {
      display: grid;
      grid-template-columns: 250px 1fr;
      dt {
        border-right: solid 1px $color-gray-700;
        white-space: nowrap;
      }
      dd {
        display: flex;
        flex-direction: column;
        gap: 5px;
        padding-left: 20px;
      }
    }
  }
  @include bp-down(md) {
    .p-privacypolicy-paragraph {
      div {
        gap: 10px;
        dt,
        dd {
          font-size: $fs-s;
          line-height: 1.75;
        }
      }
    }
    .p-privacypolicy-frameblock {
      width: 100%;
      div {
        display: flex;
        flex-direction: column;
        gap: 10px;
        dt {
          border: none;
        }
        dd {
          flex-direction: row;
          gap: 20px;
        }
      }
    }
  }
</style>
