---
import Base from "@/layouts/Base.astro";
import { t, toLang, languages, type Lang } from "@/locales/multilingual";

export async function getStaticPaths() {
  // languages に zh を入れていても、将来まだ出したくないならここで絞れる
  const buildLangs = languages.filter((l) => l !== "zh");
  return buildLangs.map((lang) => ({ params: { lang } }));
}

const safeLang: Lang = toLang(Astro.params.lang);
---

<Base lang="ja" title="会社情報">
  <h1>会社情報</h1>
  <ul>
    <li><a href="/ja/company/policy/">経営方針</a></li>
    <li><a href="/ja/company/environment/">環境理念</a></li>
    <li><a href="/ja/company/history/">会社沿革</a></li>
    <li><a href="/ja/company/profile/">会社概要</a></li>
    <li><a href="/ja/company/access/">アクセス</a></li>
  </ul>
</Base>
